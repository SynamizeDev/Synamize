---
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="container hero__inner">
    <div class="hero__content">
      <h1 id="hero-title" class="hero__title">
        <span class="hero__title-line">Turn Your Business Into</span>
        <span class="hero__title-line hero__title-line--accent">The First Choice In Your City</span>
      </h1>

      <p class="hero__sub">
        We help local businesses attract customers, build trust, and grow consistently through
        systems that actually work.
      </p>

      <div class="hero__actions">
        <a href="#contact" class="btn hero__btn hero__btn--gradient">Let's Connect</a>
        <a href="#testimonials" class="btn btn--fill hero__btn">See Client Results</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: var(--z-base);
    padding-top: clamp(6rem, 14vh, 9rem);
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
    background: transparent;
  }

  .hero__inner {
    width: min(100% - var(--container-pad) * 2, var(--container-max));
    margin-inline: auto;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-header-content);
    max-width: var(--container-max);
    margin-inline: auto;
    text-align: center;
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-display-hero);
    font-weight: 400;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line--accent {
    font-family: var(--font-accent);
    color: var(--color-accent);
  }

  .hero__sub {
    margin: 0;
    max-width: 42rem;
    font-family: var(--font-body-alt);
    font-size: var(--text-hero-sub);
    font-weight: 400;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--gap-card);
    width: 100%;
    max-width: 29.375rem;
  }

  .hero__btn {
    min-height: var(--btn-height);
    padding: var(--btn-padding-y) var(--btn-padding-x);
    font-family: var(--font-accent);
    font-size: var(--btn-font-size);
    font-weight: var(--btn-font-weight);
    letter-spacing: var(--tracking-normal);
    text-transform: none;
  }

  .hero__btn--gradient {
    background: var(--gradient-btn);
    color: var(--color-white);
    border: var(--btn-border-width) solid var(--color-border-subtle);
  }

  .hero__btn--gradient:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-1px);
  }

  @media (min-width: 640px) {
    .hero__actions {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      max-width: none;
      width: auto;
    }

    .hero__btn {
      width: auto;
    }
  }
</style>
