---
import TrustBar from '../TrustBar/TrustBar.astro';
---

<div class="hero-region">
  <div class="hero-region__backdrop" aria-hidden="true">
    <img
      class="hero-region__photo"
      src="/images/hero.png"
      alt=""
      width="1920"
      height="873"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <section id="hero" class="hero" aria-labelledby="hero-title" data-scene>
    <div class="hero__inner">
      <div class="hero__content">
        <h1 id="hero-title" class="hero__title" data-scene-item>
          <span class="hero__title-line hero__title-line--lead">Turn Your Business</span>
          <span class="hero__title-line hero__title-line--accent">
            <span class="hero__accent-part">Into The First Choice</span>
            <span class="hero__accent-part">In Your City</span>
          </span>
        </h1>

        <p class="hero__sub" data-scene-item>
          <span class="hero__sub-line">We help local businesses get more customers through content, paid ads, websites,</span>
          <span class="hero__sub-line">and automated systems - without wasting months figuring it out alone.</span>
        </p>

        <div class="hero__actions" data-scene-item>
          <a
            href="#"
            class="btn btn--gradient hero__btn hero__btn--primary"
            data-calendly-popup
          >
            Book Free Strategy Call
          </a>
          <a href="#testimonials" class="btn btn--gradient hero__btn hero__btn--secondary">See Client Results</a>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />
</div>

<style>
  /* Mobile default (<768px) */
  .hero-region {
    --hero-lead-size: 28px;
    --hero-lead-lh: 35px;
    --hero-accent-size: 32px;
    --hero-accent-lh: 40px;
    --hero-sub-size: 18px;
    --hero-sub-lh: 1.35;

    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 520px;
  }
  .hero-region__backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }

  .hero-region__photo {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    pointer-events: none;
    user-select: none;
  }

  .hero {
    position: relative;
    z-index: var(--z-base);
    flex: 1 1 auto;
    padding-top: 144px;
    padding-bottom: 0;
    background: transparent;
  }

  .hero__inner {
    width: min(100% - 40px, var(--container-max));
    margin-inline: auto;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-inline: auto;
    text-align: center;
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin: 0;
    width: 100%;
    max-width: var(--hero-title-width);
    color: var(--color-text);
  }

  .hero__title-line {
    display: block;
  }

  .hero__title .hero__title-line--lead {
    font-family: var(--font-display);
    font-size: var(--hero-lead-size);
    font-weight: 400;
    font-style: italic;
    line-height: var(--hero-lead-lh);
    letter-spacing: 0;
    color: var(--color-text);
  }

  .hero__title .hero__title-line--accent {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: -2px;
    font-family: var(--font-display);
    font-size: var(--hero-accent-size);
    font-weight: 700;
    font-style: normal;
    line-height: var(--hero-accent-lh);
    letter-spacing: 0;
    
    /* Premium gradient text with slow shine */
    background: linear-gradient(
      to right,
      var(--color-accent) 20%,
      #00FFFF 40%,
      #E0FFFF 50%,
      #00FFFF 60%,
      var(--color-accent) 80%
    );
    background-size: 200% auto;
    color: var(--color-accent); /* Fallback */
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shine 8s linear infinite;
  }

  @keyframes shine {
    to {
      background-position: 200% center;
    }
  }

  .hero__accent-part {
    display: block;
  }

  .hero__sub {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin: 0;
    width: 100%;
    max-width: var(--hero-sub-width);
    font-family: var(--font-rokkitt);
    font-size: var(--hero-sub-size);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--color-text);
  }

  .hero__sub-line {
    display: block;
    line-height: var(--hero-sub-lh);
    text-align: center;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    width: 100%;
    max-width: var(--hero-actions-width);
    margin: 0;
    align-self: center;
  }

  a.hero__btn {
    width: 100%;
    height: var(--btn-height);
    padding: var(--btn-padding-y) var(--btn-padding-x);
    box-sizing: border-box;
    white-space: nowrap;
    font-family: var(--font-display);
    font-weight: var(--btn-font-weight);
    font-size: var(--btn-font-size);
    line-height: var(--btn-line-height);
    color: var(--color-white);
    background: rgba(0, 206, 209, 0.05);
    border: 1px solid rgba(0, 206, 209, 0.3);
    border-radius: var(--radius-btn);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 0 15px rgba(0, 206, 209, 0.1);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero__btn:hover {
    background: rgba(0, 206, 209, 0.25);
    border-color: #00FFFF;
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 12px 32px rgba(0, 206, 209, 0.4), inset 0 0 20px rgba(0, 255, 255, 0.2);
  }

  .hero__btn--primary {
    box-shadow: 0 0 24px rgba(0, 206, 209, 0.2);
    background: rgba(0, 206, 209, 0.1);
  }

  /* Small tablet — side-by-side CTAs */
  @media (min-width: 480px) {
    .hero__actions {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--hero-gap-actions);
      margin-inline: auto;
    }

    a.hero__btn {
      width: auto;
      flex: 0 0 auto;
    }

    .hero__btn--primary {
      width: var(--hero-btn-primary-width);
    }

    .hero__btn--secondary {
      width: var(--hero-btn-secondary-width);
    }
  }

  /* Tablet (768–1023px) */
  @media (min-width: 768px) {
    .hero-region {
      --hero-lead-size: 34px;
      --hero-lead-lh: 42px;
      --hero-accent-size: 42px;
      --hero-accent-lh: 52px;
      --hero-sub-size: 22px;
      --hero-sub-lh: 26px;

      min-height: 640px;
    }

    .hero {
      padding-top: 150px; 
    }

    .hero__inner {
      width: min(100% - 64px, var(--container-max));
    }

    .hero__content {
      gap: 0;
    }

    .hero__sub {
      margin-top: 18px;
    }

    .hero__actions {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--hero-gap-actions);
      width: min(100%, var(--hero-actions-width));
      margin-top: 32px;
      margin-inline: auto;
    }
  }

  /* Laptop (1024–1439px) */
  @media (min-width: 1024px) {
    .hero-region {
      --hero-lead-size: 38px;
      --hero-lead-lh: 48px;
      --hero-accent-size: 48px;
      --hero-accent-lh: 60px;
      --hero-sub-size: 26px;
      --hero-sub-lh: 1.25;

      min-height: 760px;
    }

    .hero {
      padding-top: 170px;
    }

    .hero__inner {
      width: min(100% - 96px, var(--container-max));
      margin-inline: auto;
    }

    .hero__title {
      width: 100%;
      max-width: var(--hero-title-width);
    }

    .hero__content {
      gap: 0;
    }

    .hero__sub {
      margin-top: var(--hero-gap-title-sub);
    }

    .hero__actions {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--hero-gap-actions);
      width: var(--hero-actions-width);
      max-width: 100%;
      margin-top: var(--hero-gap-sub-actions);
      margin-inline: auto;
    }
  }

  /* Desktop (1440px+) — Figma 174:24129 (1264×300 @ y250) */
  @media (min-width: 1440px) {
    .hero-region {
      --hero-lead-size: var(--text-hero-lead);
      --hero-lead-lh: var(--leading-hero-lead);
      --hero-accent-size: var(--text-hero-accent);
      --hero-accent-lh: var(--leading-hero-accent);
      --hero-sub-size: 28px;
      --hero-sub-lh: 32px;

      height: var(--hero-bg-height);
      min-height: var(--hero-bg-height);
    }

    .hero-region__photo {
      object-fit: cover;
      object-position: center top;
    }

    .hero {
      padding-top: var(--hero-content-top);
      flex: 0 0 auto;
    }

    .hero__inner {
      width: var(--hero-content-width);
      margin-inline: auto;
    }

    .hero__content {
      gap: 0;
      width: var(--hero-content-width);
      min-height: var(--hero-content-height);
      align-items: center;
    }

    .hero__title {
      flex-shrink: 0;
      width: 100%;
      max-width: var(--hero-sub-width);
    }

    .hero__title .hero__title-line--accent {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: center;
      gap: 0.35em;
      white-space: nowrap;
    }

    .hero__title .hero__title-line--accent .hero__accent-part {
      display: inline;
    }

    .hero__sub {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      width: var(--hero-sub-width);
      min-height: var(--hero-sub-height);
      margin-top: var(--hero-gap-title-sub);
    }

    .hero__sub-line {
      white-space: nowrap;
    }

    .hero__actions {
      flex-shrink: 0;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--hero-gap-actions);
      width: var(--hero-actions-width);
      margin-top: var(--hero-gap-sub-actions);
      margin-inline: auto;
      align-self: center;
    }
  }
</style>
