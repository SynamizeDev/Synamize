---
const logos = ['Linear', 'Stripe', 'Notion', 'Vercel', 'Figma', 'Shopify', 'Webflow', 'Framer'];
---
<section class="trusted section" aria-label="Trusted by leading brands">
  <div class="container">
    <p class="trusted__label label" data-scramble="Trusted By Growth Leaders">Trusted By Growth Leaders</p>
  </div>
  <div class="trusted__wrap">
    <div class="trusted__track">
      {[...logos, ...logos].map((name) => (
        <span class="trusted__logo">{name}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .trusted {
    padding-block: 3rem 4rem;
    border-block: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
  }

  .trusted__label {
    text-align: center;
    margin-bottom: 2rem;
  }

  .trusted__wrap {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
  }

  .trusted__track {
    display: flex;
    gap: 4rem;
    width: max-content;
    animation: trusted-scroll 30s linear infinite;
  }

  .trusted__wrap:hover .trusted__track {
    animation-play-state: paused;
  }

  @keyframes trusted-scroll {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }

  .trusted__logo {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-secondary);
    white-space: nowrap;
    transition: color 0.25s;
  }

  .trusted__logo:hover {
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: reduce) {
    .trusted__track { animation: none; flex-wrap: wrap; justify-content: center; width: 100%; padding: 0 1rem; }
  }
</style>
