---
import './Proof.css';
---
<section class="Proof">
  <div class="Proof__container">
    <div class="reveal-on-scroll">
      <div class="Proof__stat-value">500+</div>
      <div class="Proof__stat-label">Clients Scaled</div>
    </div>
    <div class="reveal-on-scroll delay-100">
      <div class="Proof__stat-value">$100M+</div>
      <div class="Proof__stat-label">Revenue Generated</div>
    </div>
    <div class="reveal-on-scroll delay-200">
      <div class="Proof__stat-value">98%</div>
      <div class="Proof__stat-label">Retention Rate</div>
    </div>
    <div class="reveal-on-scroll delay-300">
      <div class="Proof__stat-value">24/7</div>
      <div class="Proof__stat-label">Support</div>
    </div>
  </div>
</section>
