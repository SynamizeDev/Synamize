---

const services = [
  {
    title: 'Website Development',
    description: 'Modern websites built to attract, engage, and convert customers.',
    icon: '/images/website-design.svg',
  },
  {
    title: 'Meta Ads Management',
    description: 'Facebook and Instagram advertising designed to generate leads.',
    icon: '/images/paid-advertising.svg',
  },
  {
    title: 'AI & Business Automation',
    description: 'Reduce manual work with systems that automate customer interactions.',
    icon: '/images/ai-powered.svg',
  },
  {
    title: 'Customer Acquisition Systems',
    description: 'Digital systems designed to bring more inquiries, appointments, and sales.',
    icon: '/images/content-creation.svg',
  },
  {
    title: 'Social Media Management',
    description: 'Grow your online presence with strategic content and daily management.',
    icon: '/images/social-media.svg',
    tall: true,
  },
];

---

<section id="services" class="services" aria-labelledby="services-title">
  <div class="services__inner">

    <header class="services__head">
      <p class="services__label">Services we offer</p>
      <h2 id="services-title" class="services__title">
        Systems Built To Bring More Customers To Your Business
      </h2>
    </header>

    <div class="services__grid">
      {services.map((service) => (
        <article class:list={['services__card', { 'services__card--tall': service.tall }]}>
          <div class="services__icon-glow" aria-hidden="true"></div>
          <div class="services__icon-wrap" aria-hidden="true">
            <img
              class="services__icon"
              src={service.icon}
              alt=""
              width="152"
              height="152"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="services__copy">
            <h3 class="services__card-title">{service.title}</h3>
            <p class="services__card-desc">{service.description}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────────────── */
  .services {
    padding-block: 40px 48px;
    background: transparent;
  }

  .services__inner {
    width: min(100% - 40px, 1264px);
    margin-inline: auto;
  }

  /* ── Header ───────────────────────────────────────────── */
  .services__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    text-align: center;
  }

  .services__label {
    margin: 0;
    font-family: var(--font-dancing);
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
    color: var(--color-accent);
    letter-spacing: 0;
  }

  .services__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.15;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  /* ── Grid ─────────────────────────────────────────────── */
  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  /* ── Card base ────────────────────────────────────────── */
  .services__card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 200px;
    padding: 24px;
    overflow: hidden;
    background: linear-gradient(145deg, #111827 0%, #0d1117 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
  }

  .services__card--tall {
    min-height: 320px;
  }

  /* ── Blue glow behind icon ────────────────────────────── */
  .services__icon-glow {
    position: absolute;
    top: -30px;
    right: -30px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 100, 255, 0.45) 0%, rgba(0, 80, 200, 0.15) 45%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .services__card--tall .services__icon-glow {
    top: 20px;
    right: 50%;
    transform: translateX(50%);
    width: 260px;
    height: 260px;
  }

  /* ── Icon ─────────────────────────────────────────────── */
  .services__icon-wrap {
    position: absolute;
    top: 16px;
    right: -10px;
    width: 160px;
    height: 160px;
    display: grid;
    place-items: center;
    pointer-events: none;
    z-index: 1;
  }

  .services__card--tall .services__icon-wrap {
    top: 24px;
    right: 50%;
    transform: translateX(50%);
    width: 180px;
    height: 180px;
  }

  .services__icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* ── Copy ─────────────────────────────────────────────── */
  .services__copy {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 270px;
  }

  .services__card--tall .services__copy {
    max-width: none;
    margin-top: auto;
  }

  .services__card-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.1;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .services__card-desc {
    margin: 0;
    font-family: var(--font-rokkitt);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ── Tablet 768px+ ─────────────────────────────────────── */
  @media (min-width: 768px) {
    .services {
      padding-block: 44px 52px;
    }

    .services__inner {
      width: min(100% - 64px, 1264px);
    }

    .services__head {
      gap: 14px;
      margin-bottom: 24px;
    }

    .services__title {
      font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    }

    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .services__card {
      min-height: 200px;
    }

    .services__card--tall {
      grid-column: 1 / -1;
      min-height: 280px;
    }

    .services__card-title {
      font-size: 1.5rem;
    }

    .services__card-desc {
      font-size: 1.0625rem;
    }
  }

  /* ── Desktop 1024px+ ───────────────────────────────────── */
  @media (min-width: 1024px) {
    .services {
      padding-block: 48px 60px;
    }

    .services__inner {
      width: min(100% - 96px, 1264px);
    }

    .services__head {
      width: 100%;
      max-width: var(--services-head-width);
      margin-inline: auto;
      margin-bottom: 26px;
    }

    .services__title {
      font-size: clamp(1.875rem, 2.5vw, 2.25rem);
      white-space: nowrap;
    }

    /* 3-col grid: 2×2 left + 1 tall right */
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: 200px 200px;
      gap: 14px;
    }

    .services__card {
      min-height: 0;
      height: 200px;
    }

    .services__card:nth-child(1) { grid-column: 1; grid-row: 1; }
    .services__card:nth-child(2) { grid-column: 2; grid-row: 1; }
    .services__card:nth-child(3) { grid-column: 1; grid-row: 2; }
    .services__card:nth-child(4) { grid-column: 2; grid-row: 2; }

    .services__card--tall {
      grid-column: 3;
      grid-row: 1 / span 2;
      height: 414px;
      min-height: 414px;
    }

    .services__card-title {
      font-size: 1.375rem;
    }

    .services__card-desc {
      font-size: 1rem;
    }

    /* Tall card: icon centered top, copy bottom */
    .services__card--tall .services__copy {
      max-width: 100%;
    }

    .services__card--tall .services__card-title {
      white-space: nowrap;
    }
  }

  /* ── Exact Figma 1440px+ ───────────────────────────────── */
  @media (min-width: 1440px) {
    .services {
      margin-top: calc(var(--services-pull-up) * -1);
      padding-block: var(--services-pad-top) var(--services-pad-bottom);
    }

    .services__inner {
      width: 1264px;
    }

    .services__head {
      gap: var(--services-head-gap);
      width: var(--services-head-width);
      margin-bottom: var(--services-head-margin);
      margin-inline: auto;
    }

    .services__title {
      font-size: 2.25rem;
      white-space: nowrap;
    }

    .services__grid {
      grid-template-rows: 200px 200px;
      min-height: 414px;
    }

    .services__card {
      height: 200px;
    }

    .services__card--tall {
      height: 414px;
      min-height: 414px;
    }

    .services__card-title {
      font-size: 1.5rem;
      line-height: 1.1;
    }

    .services__card-desc {
      font-size: 1.125rem;
      line-height: 1.2;
    }

    .services__icon-wrap {
      width: 152px;
      height: 152px;
      top: 22px;
      right: -22px;
    }

    .services__icon-glow {
      width: 200px;
      height: 200px;
    }

    .services__card--tall .services__icon-wrap {
      width: 170px;
      height: 166px;
      top: 48px;
    }

    .services__card--tall .services__icon-glow {
      top: -17px;
      width: 260px;
      height: 260px;
    }
  }
</style>
