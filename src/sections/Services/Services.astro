---
const services = [
  {
    title: 'Content Creation',
    description: 'Content designed to attract attention and turn viewers into customers.',
  },
  {
    title: 'Paid Advertising',
    description: 'Meta ads designed to generate qualified leads for your business.',
  },
  {
    title: 'Website Design',
    description: 'Fast websites built to convert visitors into leads and appointments.',
  },
  {
    title: 'Growth Systems',
    description: 'Automated systems that reduce manual work and improve follow-ups.',
  },
  {
    title: 'Social Media Management',
    description: 'Content, posting, and management that keeps your business visible every day.',
    tall: true,
  },
];
---

<section id="services" class="services section" aria-labelledby="services-title">
  <div class="container">
    <header class="services__head">
      <p class="label">Services we offer</p>
      <h2 id="services-title" class="services__title">
        Systems Built To Bring More Customers To Your Business
      </h2>
    </header>

    <div class="services__grid">
      {services.map((service) => (
        <article class:list={['services__card', { 'services__card--tall': service.tall }]}>
          <div class="services__glow" aria-hidden="true"></div>
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-desc">{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-bg);
  }

  .services__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-label-title);
    max-width: 55.75rem;
    margin-inline: auto;
    margin-bottom: var(--space-header-content);
    text-align: center;
  }

  .services__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-card);
  }

  .services__card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--card-gap);
    min-height: 12.5rem;
    padding: var(--card-padding);
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
  }

  .services__glow {
    position: absolute;
    top: -2rem;
    right: -2rem;
    width: var(--card-glow-size);
    height: var(--card-glow-size);
    border-radius: 50%;
    background: radial-gradient(circle, var(--card-glow-color) 0%, transparent 68%);
    pointer-events: none;
  }

  .services__card-title {
    position: relative;
    z-index: 1;
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-card-title);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .services__card--tall .services__card-title {
    font-size: var(--text-label);
  }

  .services__card-desc {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: var(--text-body-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .services__card--tall {
      grid-column: 1 / -1;
      min-height: 14rem;
    }
  }

  @media (min-width: 900px) {
    .services__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-template-rows: repeat(2, minmax(12.5rem, auto));
    }

    .services__card:nth-child(1) {
      grid-column: 1;
      grid-row: 1;
    }

    .services__card:nth-child(2) {
      grid-column: 1;
      grid-row: 2;
    }

    .services__card:nth-child(3) {
      grid-column: 2;
      grid-row: 1;
    }

    .services__card:nth-child(4) {
      grid-column: 2;
      grid-row: 2;
    }

    .services__card--tall {
      grid-column: 3;
      grid-row: 1 / span 2;
      min-height: 100%;
    }
  }
</style>
