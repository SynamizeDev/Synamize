---
const stats = [
  { value: '50M+', label: 'Views Generated' },
  { value: '527+', label: 'Leads Generated' },
  { value: '18X', label: 'Higher Engagement' },
  { value: '7 Days', label: 'To Launch Online' },
];
---

<section id="trust-bar" class="trust-bar" aria-label="Key results">
  <div class="container trust-bar__inner">
    <ul class="trust-bar__grid">
      {stats.map((stat) => (
        <li class="trust-bar__card">
          <span class="trust-bar__value">{stat.value}</span>
          <span class="trust-bar__label">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-bar {
    position: relative;
    z-index: var(--z-base);
    padding-block: 0 clamp(2rem, 5vw, 3.5rem);
  }

  .trust-bar__inner {
    width: min(100% - var(--container-pad) * 2, var(--container-max));
    margin-inline: auto;
  }

  .trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--gap-stat);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .trust-bar__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--card-gap);
    min-height: 7.125rem;
    padding: 1.5625rem clamp(1.25rem, 4vw, 3.75rem);
    text-align: center;
    background: var(--gradient-stat), var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
  }

  .trust-bar__value {
    font-family: var(--font-display);
    font-size: var(--text-stat-value);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .trust-bar__label {
    font-size: var(--text-body-lg);
    line-height: var(--leading-tight);
    color: var(--color-text-muted);
  }

  @media (min-width: 900px) {
    .trust-bar__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
