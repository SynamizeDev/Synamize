---
const stats = [
  { value: '50M+', label: 'Views Generated' },
  { value: '90%', label: 'Client Retention' },
  { value: '18X', label: 'Higher Engagement' },
  { value: '7 Days', label: 'To Launch Online' },
];
---

<section id="trust-bar" class="trust-bar" aria-label="Key results" data-scene>
  <div class="trust-bar__inner">
    <ul class="trust-bar__grid" data-scene-items>
      {stats.map((stat) => (
        <li class="trust-bar__card" data-scene-item>
          <span class="trust-bar__value">{stat.value}</span>
          <span class="trust-bar__label">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Section tokens — Frame 174:24250 */
  .trust-bar {
    --tb-card-w: 295px;
    --tb-card-h: 112px;
    --tb-gap: 28px;
    --tb-pad-x: 60px;
    --tb-pad-y: 25px;
    --tb-inner-gap: 6px;
    --tb-value-size: 33px;
    --tb-value-lh: 33px;
    --tb-label-size: 20px;
    --tb-label-lh: 23px;

    position: relative;
    z-index: var(--z-base);
    flex-shrink: 0;
    margin-top: auto;
    padding-block: 32px 40px;
  }

  .trust-bar__inner {
    width: min(100% - 40px, var(--container-max));
    margin-inline: auto;
  }

  .trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .trust-bar__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 96px;
    padding: 20px 16px;
    text-align: center;
    background: var(--gradient-stat), var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
  }

  .trust-bar__value {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: 0;
  }

  .trust-bar__label {
    font-family: var(--font-rokkitt);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-secondary);
    letter-spacing: 0;
  }

  /* Tablet (768–1023px) */
  @media (min-width: 768px) {
    .trust-bar__inner {
      width: min(100% - 64px, var(--container-max));
    }

    .trust-bar__grid {
      gap: 16px;
    }

    .trust-bar__card {
      min-height: 104px;
      padding: 22px 24px;
    }

    .trust-bar__value {
      font-size: 30px;
    }

    .trust-bar__label {
      font-size: 18px;
    }
  }

  /* Laptop (1024–1439px) */
  @media (min-width: 1024px) {
    .trust-bar {
      padding-block: 40px 64px;
    }

    .trust-bar__inner {
      width: min(100% - 96px, var(--container-max));
    }

    .trust-bar__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--tb-gap);
    }

    .trust-bar__card {
      align-items: center;
      justify-content: center;
      min-height: var(--tb-card-h);
      padding: var(--tb-pad-y) clamp(24px, 4vw, var(--tb-pad-x));
      gap: var(--tb-inner-gap);
      text-align: center;
    }

    .trust-bar__value {
      font-size: 31px;
    }

    .trust-bar__label {
      font-size: 19px;
    }
  }

  /* Desktop (1440px+) — Figma: stats row at bottom of 873px hero */
  @media (min-width: 1440px) {
    .trust-bar {
      padding-block: 0;
      margin-top: var(--hero-gap-actions-trust);
    }

    .trust-bar__inner {
      width: var(--container-max);
    }

    .trust-bar__grid {
      grid-template-columns: repeat(4, var(--tb-card-w));
      gap: var(--tb-gap);
    }

    .trust-bar__card {
      width: var(--tb-card-w);
      height: var(--tb-card-h);
      min-height: var(--tb-card-h);
      padding: var(--tb-pad-y) var(--tb-pad-x);
      gap: var(--tb-inner-gap);
    }

    .trust-bar__value {
      font-size: var(--tb-value-size);
      line-height: var(--tb-value-lh);
      min-height: var(--tb-value-lh);
    }

    .trust-bar__label {
      font-size: var(--tb-label-size);
      line-height: var(--tb-label-lh);
      min-height: var(--tb-label-lh);
      white-space: nowrap;
    }
  }
</style>
