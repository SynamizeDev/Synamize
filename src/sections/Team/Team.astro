---
import jayImage from '../../assets/images/team/jay-prajapat.png';
import jatinImage from '../../assets/images/team/jatin-prajapat.png';

const members = [
  {
    name: 'Jay Prajapat',
    role: 'CO-Founder',
    bio: 'Focused on systems, operations, and growth strategies that help businesses scale efficiently and build a stronger online presence.',
    image: jayImage.src,
    imageAlt: 'Jay Prajapat, Co-Founder of Synamize',
  },
  {
    name: 'Jatin Prajapat',
    role: 'CO-Founder',
    bio: 'Focused on customer acquisition, advertising, and digital systems that help businesses attract leads and drive growth.',
    image: jatinImage.src,
    imageAlt: 'Jatin Prajapat, Co-Founder of Synamize',
  },
];
---

<section id="team" class="team section" aria-labelledby="team-heading">
  <div class="container">
    <header class="team__head">
      <div class="team__head-main">
        <p class="team__label">Meet The Team Behind Synamize</p>
        <h2 id="team-heading" class="team__title">
          <span class="team__title-line">Our focus isn't vanity metrics,</span>
          <span class="team__title-line">it's real business growth.</span>
        </h2>
      </div>
      <div class="team__intro">
        <p>
          Too many businesses struggle online despite offering great services. Synamize exists
          to help businesses attract customers through content, advertising, and digital systems.
        </p>
        <p>
          Today, Synamize helps brands combine modern content, paid advertising and digital systems
          to attract more customers and scale with clarity.
        </p>
      </div>
    </header>

    <ul class="team__grid">
      {members.map((member) => (
        <li>
          <article class="team__card">
            <div class="team__card-glow" aria-hidden="true"></div>
            <div class="team__media">
              {member.image ? (
                <img
                  class="team__image"
                  src={member.image}
                  alt={member.imageAlt}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="team__placeholder" aria-hidden="true">
                  <span class="team__placeholder-label">{member.name}</span>
                </div>
              )}
            </div>

            <div class="team__meta">
              <h3 class="team__name">{member.name}</h3>
              <p class="team__role">{member.role}</p>
            </div>

            <p class="team__bio">{member.bio}</p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .team {
    --team-card-bg: #111111;
    --team-card-stroke-w: 1px;
    --team-card-stroke: linear-gradient(
      90deg,
      rgb(0 112 255 / 0.4) 0%,
      rgb(0 112 255 / 0.04) 100%
    );
    --team-card-bottom-glow: linear-gradient(
      90deg,
      rgb(0 112 255 / 0) 0%,
      rgb(0 112 255 / 0.4) 50%,
      rgb(0 112 255 / 0) 100%
    );

    background: transparent;
    padding-block-start: calc(var(--space-section) / 2);
    padding-block-end: calc(var(--space-section) / 2);
  }

  .team__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-header-content);
    margin-bottom: var(--space-header-content);
  }

  .team__head-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-label-title);
    max-width: 31.25rem;
  }

  .team__label {
    margin: 0;
    font-family: var(--font-dancing);
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
    color: var(--color-accent);
    letter-spacing: 0;
  }

  .team__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .team__title-line {
    display: block;
  }

  .team__intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 36.8125rem;
  }

  .team__intro p {
    margin: 0;
    font-family: var(--font-rokkitt);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
  }

  .team__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-stat);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .team__card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.375rem;
    min-height: 30.75rem;
    padding: 2.25rem var(--card-padding);
    text-align: center;
    overflow: hidden;
    background: var(--team-card-bg);
    border: none;
    border-radius: var(--card-radius);
  }

  .team__card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: var(--team-card-stroke-w);
    background: var(--team-card-stroke);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
    z-index: 1;
  }

  .team__card-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--team-card-bottom-glow);
    box-shadow: 0 0 16px rgb(0 112 255 / 0.5);
    pointer-events: none;
    z-index: 2;
  }

  .team__media,
  .team__meta,
  .team__bio {
    position: relative;
    z-index: 3;
  }

  .team__media {
    width: 100%;
    max-width: 16.4375rem;
  }

  .team__image,
  .team__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--card-radius);
    object-fit: cover;
    object-position: center top;
  }

  .team__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-stat), var(--color-surface-elevated);
    border: 1px solid var(--card-border);
  }

  .team__placeholder-label {
    font-size: var(--text-footer-link);
    line-height: var(--leading-tight);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .team__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .team__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-card-title);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text);
    text-transform: capitalize;
  }

  .team__role {
    margin: 0;
    font-family: var(--font-dancing);
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
    color: var(--color-accent);
    letter-spacing: 0;
  }

  .team__bio {
    margin: 0;
    max-width: 35.5rem;
    font-family: var(--font-rokkitt);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text-muted);
  }

  @media (min-width: 900px) {
    .team__head {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--gap-stat);
    }

    .team__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
