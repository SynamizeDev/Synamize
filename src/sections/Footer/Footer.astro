---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer__inner">
    <a href="#" class="footer__logo">Synamize</a>
    <nav class="footer__nav" aria-label="Footer">
      <a href="#services" class="link-underline">Services</a>
      <a href="#work" class="link-underline">Work</a>
      <a href="mailto:hello@synamize.agency" class="link-underline">Contact</a>
    </nav>
    <p class="footer__copy">&copy; {year}</p>
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 0 3rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-black);
  }

  .footer__inner {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr auto auto;
      align-items: center;
    }
  }

  .footer__logo {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-white);
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer__copy {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    letter-spacing: 0.06em;
  }
</style>
