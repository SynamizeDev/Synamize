    border-radius: var(--wc-card-radius);
  }

  .why__card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: var(--wc-card-stroke-w);
    background: var(--wc-card-stroke);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
    z-index: 2;
  }

  .why__card-pattern {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    opacity: var(--wc-pattern-opacity);
    pointer-events: none;
  }

  .why__card-glow {
    position: absolute;
    top: 50%;
    right: var(--wc-glow-right);
    width: min(var(--wc-glow-w), 55%);
    height: var(--wc-glow-h);
    max-height: 100%;
    transform: translateY(-50%);
    object-fit: contain;
    object-position: right center;
    pointer-events: none;
  }

  .why__card-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--wc-label-body-gap);
    width: 100%;
    min-height: 100%;
  }

  .why__card-label {
    margin: 0;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
    color: var(--color-accent);
  }

  .why__card-body {
