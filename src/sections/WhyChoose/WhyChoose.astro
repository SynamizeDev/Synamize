---
const reasons = [
  {
    title: 'Built For Local Businesses',
    text: 'Strategies built for businesses that want more local customers and stronger online presence.',
  },
  {
    title: 'Results-Focused Approach',
    text: 'Every system we build is designed to generate leads, trust, and conversions.',
  },
  {
    title: 'Non Generic Content',
    text: 'Content designed specifically for your audience and business goals.',
  },
  {
    title: 'Long-Term Growth',
    text: 'Sustainable systems built for growth beyond short-term trends.',
  },
];
---

<section id="why" class="why section" aria-labelledby="why-heading">
  <div class="container">
    <header class="why__head">
      <div class="why__head-main">
        <p class="label">Why Businesses Choose Synamize</p>
        <h2 id="why-heading" class="why__title">We Build Systems That Grow Businesses</h2>
      </div>
      <p class="why__intro">
        Book a free strategy call and we'll show you exactly where your business is losing
        attention, leads and potential revenue online.
      </p>
    </header>

    <ul class="why__list">
      {reasons.map((reason) => (
        <li>
          <article class="why__card">
            <h3 class="why__card-title">{reason.title}</h3>
            <p class="why__card-text">{reason.text}</p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .why {
    background: var(--color-bg);
  }

  .why__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-header-content);
    margin-bottom: var(--space-header-content);
  }

  .why__head-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-label-title);
    max-width: 39.875rem;
  }

  .why__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .why__intro {
    margin: 0;
    max-width: 36.8125rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  .why__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-card);
  }

  .why__card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--card-gap);
    min-height: 11.25rem;
    padding: var(--card-padding);
    background: var(--color-surface);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
    transition: border-color 0.35s var(--ease-luxury), background-color 0.35s var(--ease-luxury);
  }

  .why__card:hover {
    border-color: var(--color-border-strong);
    background: var(--color-surface-elevated);
  }

  .why__card-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-card-title);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
    text-transform: capitalize;
  }

  .why__card-text {
    margin: 0;
    max-width: 52rem;
    font-size: var(--text-body-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
  }

  @media (min-width: 900px) {
    .why__head {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--gap-stat);
    }

    .why__list {
      gap: 1.5rem;
    }

    .why__card {
      min-height: 11.25rem;
    }
  }
</style>
