---
const reasons = [
  {
    label: 'Local Business Focused',
    title: 'Built For Local Businesses',
    text: 'We understand the challenges local businesses face and build strategies designed to increase visibility, attract customers, and support long-term growth.',
  },
  {
    label: 'Results Over Vanity',
    title: 'Focused On Real Results',
    text: 'Every campaign, website, and system we create is designed to generate more inquiries, appointments, and customers—not just likes and impressions.',
  },
  {
    label: 'Custom Strategy',
    title: 'Built Around Your Business',
    text: 'No generic templates or one-size-fits-all solutions. Every strategy is tailored to your business, audience, goals, and local market.',
  },
  {
    label: 'Complete Growth Systems',
    title: 'More Than Just Marketing',
    text: 'We combine content, advertising, websites, and automation into one system designed to help your business grow consistently.',
  },
];
---

<section id="why" class="why" aria-labelledby="why-heading" data-scene>
  <div class="why__inner">
    <header class="why__head">
      <div class="why__head-main" data-scene-item>
        <p class="why__label">Why Businesses Choose Synamize</p>
        <h2 id="why-heading" class="why__title">We Build Systems That Grow Businesses</h2>
      </div>
      <p class="why__intro" data-scene-item>
        Book a free strategy call and we'll show you exactly where your business is losing
        attention, leads and potential revenue online.
      </p>
    </header>

    <ul class="why__list" data-scene-items>
      {reasons.map((reason) => (
        <li data-scene-item>
          <article class="why__card">
            <img
              class="why__card-pattern"
              src="/images/why-synamize.png"
              alt=""
              width="1264"
              height="160"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <img
              class="why__card-glow"
              src="/images/Ellipse 1.png"
              alt=""
              width="429"
              height="160"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <div class="why__card-content">
              <p class="why__card-label">{reason.label}</p>
              <div class="why__card-body">
                <h3 class="why__card-title">{reason.title}</h3>
                <p class="why__card-text">{reason.text}</p>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
