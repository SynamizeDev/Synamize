    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .why__intro {
    margin: 0;
    font-family: var(--font-rokkitt);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
  }

  .why__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .why__card {
    position: relative;
    display: flex;
    align-items: stretch;
    width: 100%;
    min-height: 140px;
    padding: var(--wc-card-pad);
    overflow: hidden;
    background: var(--color-surface);
