---
const reasons = [
  {
    title: 'Built For Local Businesses',
    text: 'We design specifically for businesses that want more customers and stronger online presence.',
  },
  {
    title: 'Results-Focused Approach',
    text: 'Every system we build is designed to generate leads, sales, and revenue.',
  },
  {
    title: 'Non-Generic Content',
    text: 'Unique designs and copy tailored to your brand\'s specific goals.',
  },
  {
    title: 'Long-Term Growth',
    text: 'Systems that are built for growth and scale with your business.',
  },
];
---

<section id="why" class="why" aria-labelledby="why-heading">
  <div class="why__inner">
    <header class="why__head">
      <div class="why__head-main">
        <p class="why__label">Why Businesses Choose Synamize</p>
        <h2 id="why-heading" class="why__title">We Build Systems That Grow Businesses</h2>
      </div>
      <p class="why__intro">
        Book a free strategy call and we'll show you exactly where your business is losing
        attention, leads and potential revenue online.
      </p>
    </header>

    <ul class="why__list">
      {reasons.map((reason) => (
        <li>
          <article class="why__card">
            <img
              class="why__card-pattern"
              src="/images/why-synamize.png"
              alt=""
              width="1264"
              height="160"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <img
              class="why__card-glow"
              src="/images/Ellipse 1.png"
              alt=""
              width="429"
              height="160"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <div class="why__card-content">
              <p class="why__card-label">Choose Synamize</p>
              <div class="why__card-body">
                <h3 class="why__card-title">{reason.title}</h3>
                <p class="why__card-text">{reason.text}</p>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /*
   * Why Choose — Frame 174:24118 (cached metadata)
   * Section 174:24252 · cards 1264×160
   */
  .why {
    --wc-section-pad-top: 90px;
    --wc-section-pad-bottom: 90px;
    --wc-container: 1264px;
    --wc-head-gap: 28px;
    --wc-head-main-w: 653px;
    --wc-intro-w: 589px;
    --wc-head-stack-gap: 16px;
    --wc-head-margin: 60px;
    --wc-label-size: 24px;
    --wc-title-size: 36px;
    --wc-intro-size: 20px;
    --wc-card-w: 1264px;
    --wc-card-h: 160px;
    --wc-card-pad: 26px;
    --wc-card-radius: 16px;
    --wc-row-gap: 24px;
    --wc-card-label-size: 20px;
    --wc-card-title-size: 30px;
    --wc-card-title-lh: 30px;
    --wc-card-text-size: 20px;
    --wc-card-text-lh: 24px;
    --wc-card-text-max: 851px;
    --wc-label-body-gap: 20px;
    --wc-title-text-gap: 0px;
    --wc-pattern-opacity: 1;
    --wc-glow-right: -96px;
    --wc-glow-w: 429px;
    --wc-glow-h: 160px;
    --wc-card-stroke-w: 1px;
    /* #0070FF · 0% @ 100% → 100% @ 10% · stroke opacity 40% */
    --wc-card-stroke: linear-gradient(
      90deg,
      rgb(0 112 255 / 0.4) 0%,
      rgb(0 112 255 / 0.04) 100%
    );

    background: transparent;
    padding-block: 32px 40px;
  }

  .why__inner {
    width: min(100% - 40px, var(--wc-container));
    margin-inline: auto;
  }

  .why__head {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 40px;
  }

  .why__head-main {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: none;
  }

  .why__label {
    margin: 0;
    font-family: var(--font-dancing);
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
    color: var(--color-accent);
    letter-spacing: 0;
  }

  .why__title {
