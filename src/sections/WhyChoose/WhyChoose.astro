    }

    .why__card-text {
      font-size: var(--wc-card-text-size);
      max-width: var(--wc-card-text-max);
    }
  }

  /* Desktop (1440px+) — exact Figma */
  @media (min-width: 1440px) {
    .why {
      padding-block: var(--wc-section-pad-top) var(--wc-section-pad-bottom);
    }

    .why__inner {
      width: var(--wc-container);
    }

    .why__head {
      margin-bottom: var(--wc-head-margin);
    }

    .why__head-main {
      gap: var(--wc-head-stack-gap);
    }

    .why__label {
