---
const testimonial = {
  quote:
    'Jay is a beast! He\'s super knowledgeable about social media and how to use it to grow your business. He\'s also proactive and takes feedback well. Overall it\'s been a pleasure working with him!',
  name: 'Brian Oliver',
  role: 'Head of Marketing',
  image: '/images/brian-oliver.png',
  imageAlt: 'Brian Oliver, Head of Marketing',
};
---

<section id="testimonials" class="testimonials" aria-labelledby="testimonials-title" data-scene>
  <div class="testimonials__inner">
    <header class="testimonials__head">
      <div class="testimonials__head-main" data-scene-item>
        <p class="testimonials__label">Reviews</p>
        <h2 id="testimonials-title" class="testimonials__title">What Our Clients Say</h2>
      </div>
      <p class="testimonials__intro" data-scene-item>
        Book a free strategy call and we'll show you exactly where your business is losing
        attention, leads and potential revenue online.
      </p>
    </header>

    <article class="testimonials__panel" data-scene-item>
      <div class="testimonials__body">
        <div class="testimonials__content">
          <div class="testimonials__quote-block">
            <blockquote class="testimonials__quote">
              <p>&ldquo;{testimonial.quote}&rdquo;</p>
            </blockquote>

            <footer class="testimonials__author">
              <cite class="testimonials__name">{testimonial.name}</cite>
              <p class="testimonials__role">{testimonial.role}</p>
            </footer>
          </div>
        </div>

        <div class="testimonials__media">
          <img
            class="testimonials__image"
            src={testimonial.image}
            alt={testimonial.imageAlt}
            width="466"
            height="320"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  /*
   * Reviews / Testimonials — Frame 174:24146 (header) · 174:24147 (panel)
   */
  .testimonials {
    --tm-section-pad-top: 90px;
    --tm-section-pad-bottom: 90px;
    --tm-container: 1264px;
    --tm-head-gap: 28px;
    --tm-head-main-w: 340px;
    --tm-intro-w: 589px;
    --tm-head-stack-gap: 16px;
    --tm-head-margin: 60px;
    --tm-panel-pad: 26px;
    --tm-panel-radius: 16px;
    --tm-body-gap: 28px;
    --tm-content-w: 742px;
    --tm-media-w: 466px;
    --tm-media-h: 320px;
    --tm-label-size: 24px;
    --tm-title-size: 36px;
    --tm-intro-size: 20px;
    --tm-quote-size: 24px;
    --tm-quote-lh: 28px;
    --tm-name-size: 24px;
    --tm-role-size: 20px;
    --tm-metric-value-size: 24px;
    --tm-metric-label-size: 18px;
    --tm-metric-gap: 10px;
    --tm-metric-pad: 26px;
    --tm-quote-author-gap: 16px;
    --tm-quote-max-w: 520px;
    --tm-divider-w: 100%;
    --tm-divider-gap: 12px;
    --tm-divider-stroke: linear-gradient(
      90deg,
      rgb(0 112 255 / 0) 0%,
      #00ced1 50%,
      rgb(0 112 255 / 0) 100%
    );
    --tm-stats-gap: 0px;
    --tm-divider: 1px;

    background: transparent;
    padding-block: 32px 40px;
  }

  .testimonials__inner {
    width: min(100% - 40px, var(--tm-container));
    margin-inline: auto;
  }

  .testimonials__head {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 40px;
  }

  .testimonials__head-main {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: none;
  }

  .testimonials__label {
    margin: 0;
    font-family: var(--font-dancing);
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
    color: var(--color-accent);
    letter-spacing: 0;
  }

  .testimonials__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: 0;
  }

  .testimonials__intro {
    margin: 0;
    font-family: var(--font-rokkitt);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
  }

  .testimonials__panel {
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--tm-panel-radius);
    overflow: hidden;
  }

  .testimonials__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .testimonials__content {
    min-width: 0;
  }

  .testimonials__quote-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--tm-quote-author-gap);
    width: 100%;
    padding-inline: 16px;
  }

  .testimonials__divider {
    position: relative;
    flex-shrink: 0;
    width: var(--tm-divider-w);
    height: 4px;
    margin-block: 24px;
    border: none;
    background: var(--tm-divider-stroke);
  }

  .testimonials__quote {
    margin: 0;
    padding: 0;
    border: none;
    width: 100%;
  }

  .testimonials__quote p {
    margin: 0 auto;
    max-width: var(--tm-quote-max-w);
    font-family: var(--font-rokkitt);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
    text-align: center;
  }

  .testimonials__author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin: 0;
    width: 100%;
  }

  .testimonials__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    font-style: normal;
    line-height: 1;
    color: var(--color-text);
  }

  .testimonials__role {
    margin: 0;
    font-family: var(--font-rokkitt);
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
    color: var(--color-text-muted);
  }

  .testimonials__metrics {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .testimonials__metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--tm-metric-gap);
    padding: 20px 0;
    text-align: center;
    border-bottom: var(--tm-divider) solid var(--color-border);
  }

  .testimonials__metric--last {
    border-bottom: none;
  }

  .testimonials__metric-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .testimonials__metric-label {
    font-family: var(--font-rokkitt);
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
    color: var(--color-text-muted);
  }

  .testimonials__media {
    min-width: 0;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonials__image {
    display: block;
    width: 180px;
    height: 180px;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    object-fit: cover;
    object-position: center top;
  }

  /* Tablet (768–1023px) */
  @media (min-width: 768px) {
    .testimonials {
      padding-block: 40px 48px;
    }

    .testimonials__inner {
      width: min(100% - 64px, var(--tm-container));
    }

    .testimonials__head {
      gap: 28px;
      margin-bottom: 48px;
    }

    .testimonials__head-main {
      gap: 14px;
    }

    .testimonials__title {
      font-size: 32px;
    }

    .testimonials__intro {
      font-size: 19px;
    }

    .testimonials__panel {
      padding: 32px;
    }

    .testimonials__body {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
    }

    .testimonials__media {
      margin-top: 24px;
    }

    .testimonials__quote p {
      font-size: 23px;
    }

    .testimonials__name,
    .testimonials__metric-value {
      font-size: 23px;
    }

    .testimonials__metrics {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .testimonials__metric {
      align-items: center;
      text-align: center;
      padding: 16px var(--tm-metric-pad) 0;
      border-bottom: none;
      border-right: var(--tm-divider) solid var(--color-border);
    }

    .testimonials__metric--last {
      border-right: none;
    }

    .testimonials__image {
      width: 200px;
      height: 200px;
      aspect-ratio: 1 / 1;
    }
  }

  /* Laptop (1024–1439px) */
  @media (min-width: 1024px) {
    .testimonials {
      padding-block: 60px 70px;
    }

    .testimonials__inner {
      width: min(100% - 96px, var(--tm-container));
    }

    .testimonials__head {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--tm-head-gap);
      margin-bottom: 52px;
    }

    .testimonials__head-main {
      flex: 0 1 var(--tm-head-main-w);
      max-width: var(--tm-head-main-w);
      gap: 15px;
    }

    .testimonials__intro {
      flex: 0 1 var(--tm-intro-w);
      max-width: var(--tm-intro-w);
      font-size: var(--tm-intro-size);
      line-height: 1.2;
      text-align: right;
    }

    .testimonials__title {
      font-size: 34px;
    }

    .testimonials__panel {
      padding: var(--tm-panel-pad);
    }

    .testimonials__body {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
    }

    .testimonials__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-block: 0;
    }

    .testimonials__quote-block {
      padding-inline: 24px;
    }

    .testimonials__divider {
      width: calc(100% + var(--tm-body-gap));
      max-width: none;
    }

    .testimonials__metrics {
      align-self: stretch;
    }

    .testimonials__media {
      align-self: center;
      margin-top: 0;
    }

    .testimonials__metric {
      align-items: center;
      text-align: center;
    }

    .testimonials__image {
      width: 260px;
      height: 260px;
      aspect-ratio: 1 / 1;
      flex-shrink: 0;
    }
  }

  /* Desktop (1440px+) — exact Figma */
  @media (min-width: 1440px) {
    .testimonials {
      padding-block: var(--tm-section-pad-top) var(--tm-section-pad-bottom);
    }

    .testimonials__inner {
      width: var(--tm-container);
    }

    .testimonials__head {
      margin-bottom: var(--tm-head-margin);
    }

    .testimonials__head-main {
      gap: var(--tm-head-stack-gap);
    }

    .testimonials__label {
      font-size: var(--tm-label-size);
    }

    .testimonials__title {
      font-size: var(--tm-title-size);
    }

    .testimonials__body {
      gap: 64px;
    }

    .testimonials__quote p {
      font-size: var(--tm-quote-size);
      line-height: var(--tm-quote-lh);
    }

    .testimonials__name {
      font-size: var(--tm-name-size);
    }

    .testimonials__role {
      font-size: var(--tm-role-size);
    }

    .testimonials__metric-value {
      font-size: var(--tm-metric-value-size);
    }

    .testimonials__metric-label {
      font-size: var(--tm-metric-label-size);
    }
  }
</style>
