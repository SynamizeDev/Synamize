---
import './Founder.css';
---
<section class="Founder">
  <div class="Founder__container">
    <div class="Founder__image reveal-on-scroll" aria-hidden="true"></div>
    <div class="Founder__content">
      <h2 class="Founder__title reveal-on-scroll delay-100">Meet the Founder</h2>
      <blockquote class="Founder__quote reveal-on-scroll delay-200">
        "We don't just run ads. We build engines that drive sustainable growth for the world's most ambitious brands."
      </blockquote>
      <div class="Founder__name reveal-on-scroll delay-300">Jatin, Founder</div>
    </div>
  </div>
</section>
