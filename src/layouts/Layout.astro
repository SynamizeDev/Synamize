---

import SmoothScroll from '../components/SmoothScroll.astro';

import ScrollProgress from '../components/ScrollProgress.astro';

import Ambient from '../components/Ambient.astro';

import Nav from '../components/Nav.astro';

import SiteMotion from '../components/islands/SiteMotion';

import Calendly from '../components/Calendly.astro';

import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import urbanistLatin from '@fontsource-variable/urbanist/files/urbanist-latin-wght-normal.woff2?url';
import loraLatin from '@fontsource/lora/files/lora-latin-400-normal.woff2?url';
import rokkitt400 from '@fontsource/rokkitt/files/rokkitt-latin-400-normal.woff2?url';
import rokkitt700 from '@fontsource/rokkitt/files/rokkitt-latin-700-normal.woff2?url';

import '@fontsource-variable/afacad-flux/wght.css';
import '@fontsource/dancing-script/latin-400.css';
import '@fontsource/dancing-script/latin-700.css';

const criticalFontFace = `
@font-face{font-family:'Inter Variable';font-style:normal;font-display:block;font-weight:100 900;src:url('${interLatin}') format('woff2-variations')}
@font-face{font-family:'Urbanist Variable';font-style:normal;font-display:block;font-weight:100 900;src:url('${urbanistLatin}') format('woff2-variations')}
@font-face{font-family:'Lora';font-style:normal;font-display:block;font-weight:400;src:url('${loraLatin}') format('woff2')}
@font-face{font-family:'Rokkitt';font-style:normal;font-display:block;font-weight:400;src:url('${rokkitt400}') format('woff2')}
@font-face{font-family:'Rokkitt';font-style:normal;font-display:block;font-weight:700;src:url('${rokkitt700}') format('woff2')}
`;

import '../styles/tokens.css';

import '../styles/typography.css';

import '../styles/global.css';

import '../styles/components.css';



interface Props {

  title: string;

  description: string;

  image?: string;

  noIndex?: boolean;

}



const { title, description, image = '/favicon.svg', noIndex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://synamize.agency');

---



<!DOCTYPE html>

<html lang="en">

  <head>

    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preload" href={interLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={urbanistLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={loraLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={rokkitt400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={rokkitt700} as="font" type="font/woff2" crossorigin />
    <style is:inline set:html={criticalFontFace} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:title" content={title} />

    <meta property="og:description" content={description} />

    <meta property="og:type" content="website" />

    <meta property="og:url" content={canonicalURL} />

    <meta property="og:image" content={image} />

    <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />

  </head>

  <body>

    <ScrollProgress />

    <Ambient />

    <Nav />

    <SiteMotion client:load />

    <slot />

    <SmoothScroll />

    <Calendly />

  </body>

</html>



<script>

  import { gsap } from 'gsap';

  import { ScrollTrigger } from 'gsap/ScrollTrigger';



  gsap.registerPlugin(ScrollTrigger);



  let timer: ReturnType<typeof setTimeout>;

  const refresh = () => {

    clearTimeout(timer);

    timer = setTimeout(() => ScrollTrigger.refresh(), 150);

  };

  window.addEventListener('load', refresh, { once: true });

  window.addEventListener('resize', refresh, { passive: true });

</script>

