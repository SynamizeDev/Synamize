---
import Layout from '../layouts/Layout.astro';
import Hero from '../sections/Hero/Hero.astro';
import Services from '../sections/Services/Services.astro';
import Testimonials from '../sections/Testimonials/Testimonials.astro';
import WhyChoose from '../sections/WhyChoose/WhyChoose.astro';
import Team from '../sections/Team/Team.astro';
import Footer from '../sections/Footer/Footer.astro';

const meta = {
  title: 'Synamize — Social Media & Lead Generation for Local Businesses',
  description:
    'Synamize helps local businesses grow with social media management, organic lead generation, and targeted paid advertising. Get more customers in your city.',
};
---

<Layout title={meta.title} description={meta.description}>
  <main>
    <Hero />
    <Services />
    <Testimonials />
    <WhyChoose />
    <Team />
  </main>
  <Footer />
</Layout>
