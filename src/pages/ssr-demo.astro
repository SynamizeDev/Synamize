---
import Layout from '../layouts/Layout.astro';

const buildTime = new Date().toISOString();
---

<Layout 
  title="SSR Demo | Synamize"
  description="Demonstration of opt-in server-side rendering."
  noIndex={true}
>
  <main class="min-h-screen bg-gray-900 text-white flex items-center justify-center">
    <div class="max-w-2xl w-full p-8 border border-white/10 rounded-xl bg-white/5 backdrop-blur">
      <h1 class="text-3xl font-bold mb-6">Server-Side Rendering (SSR)</h1>
      <p class="text-gray-400 mb-8">
        This page is statically generated at build time. Live values below are filled in the browser.
      </p>

      <div class="space-y-4">
        <div class="p-4 bg-black/30 rounded">
          <div class="text-sm text-gray-500 mb-1">Build Timestamp</div>
          <div class="font-mono text-green-400">{buildTime}</div>
        </div>

        <div class="p-4 bg-black/30 rounded">
          <div class="text-sm text-gray-500 mb-1">Your User Agent</div>
          <div id="user-agent" class="font-mono text-blue-400 text-sm break-all">Loading…</div>
        </div>
      </div>

      <script>
        const el = document.getElementById('user-agent');
        if (el) el.textContent = navigator.userAgent;
      </script>

      <div class="mt-8 pt-6 border-t border-white/10 text-center">
        <a href="/" class="text-white underline hover:text-gray-300">Back to Home</a>
      </div>
    </div>
  </main>
</Layout>
