---
import Logo from './Logo.astro';

const links = [
  { href: '#services', label: 'Services' },
  { href: '#testimonials', label: 'Results' },
  { href: '#team', label: 'Team' },
  { href: '#contact', label: 'Contact' },
];
---
<header class="nav" id="nav" data-nav>
  <nav class="nav__inner" aria-label="Main">
    <a href="#" class="nav__logo" aria-label="Synamize home">
      <Logo class="nav__logo-img" />
    </a>

    <ul class="nav__links" hidden>
      {links.map((l) => (
        <li><a href={l.href} class="link-underline">{l.label}</a></li>
      ))}
    </ul>

    <a href="#contact" class="btn btn--gradient nav__cta" data-calendly-popup>Lets Connect</a>

    <button
      type="button"
      class="nav__toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
      data-nav-toggle
    >
      <span></span><span></span>
    </button>
  </nav>

  <div class="nav__drawer" id="nav-drawer" data-nav-drawer hidden>
    {links.map((l) => (
      <a href={l.href} class="nav__drawer-link">{l.label}</a>
    ))}
    <a href="#contact" class="btn btn--gradient nav__drawer-cta" data-calendly-popup>Lets Connect</a>
  </div>
</header>

<script>
  const nav = document.querySelector('[data-nav]');
  const toggle = document.querySelector('[data-nav-toggle]');
  const drawer = document.querySelector('[data-nav-drawer]');

  window.addEventListener(
    'scroll',
    () => nav?.classList.toggle('nav--solid', window.scrollY > 60),
    { passive: true }
  );

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    if (drawer) drawer.hidden = open;
    document.body.style.overflow = open ? '' : 'hidden';
  });

  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (!toggle || !drawer) return;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      drawer.hidden = true;
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  /* Mobile default (<768px) */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    height: 65px;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.4s var(--ease-luxury), border-color 0.4s var(--ease-luxury);
  }

  .nav--solid {
    background: var(--color-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--color-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    width: min(100% - 40px, 1264px);
    margin: 0 auto;
  }

  .nav__logo {
    display: block;
    flex-shrink: 0;
    width: 140px;  
  }

  .nav__logo-img {
    display: block;
    width: 96px;
    height: auto;
    aspect-ratio: 200 / 38;
  }

  .nav__links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }

  .nav__cta {
    display: none;
    flex-shrink: 0;
    width: auto;
    padding-inline: 20px;
    box-sizing: border-box;
  }

  .nav__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 7px;
    width: 44px;
    height: 44px;
    padding: 4px;
  }

  .nav__toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-white);
    transition: transform 0.35s var(--ease-luxury), opacity 0.35s var(--ease-luxury);
  }

  .nav__toggle[aria-expanded='true'] span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .nav__toggle[aria-expanded='true'] span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  .nav__drawer {
    position: fixed;
    inset: 65px 0 0;
    z-index: calc(var(--z-nav) - 1);
    background: var(--color-black);
    padding: 32px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-top: 1px solid var(--color-border);
    overflow-y: auto;
  }

  .nav__drawer[hidden] {
    display: none;
  }

  .nav__drawer-link {
    font-family: var(--font-accent);
    font-size: 24px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-white);
  }

  .nav__drawer-cta {
    align-self: flex-start;
    margin-top: 8px;
  }

  /* Tablet (768–1023px) */
  @media (min-width: 768px) {
    .nav {
      height: 75px;
    }

    .nav__inner {
      width: min(100% - 64px, 1264px);
    }

    .nav__logo-img {
      width: 104px;
    }

    .nav__drawer {
      inset: 75px 0 0;
      padding-inline: 32px;
    }
  }

  /* Laptop (1024–1439px) */
  @media (min-width: 1024px) {
    .nav {
      height: 85px;
    }

    .nav__inner {
      width: min(100% - 96px, 1264px);
    }

    .nav__logo-img {
      width: 110px;
    }

    .nav__cta {
      display: inline-flex;
    }

    .nav__toggle {
      display: none;
    }

    .nav__drawer {
      display: none !important;
    }

    .nav__drawer {
      inset: 85px 0 0;
    }
  }

  /* Desktop (1440px+) — exact Figma */
  @media (min-width: 1440px) {
    .nav {
      height: var(--nav-height);
    }

    .nav__inner {
      width: 1264px;
    }

    .nav__logo-img {
      width: 110px;
      height: auto;
    }

    .nav__cta {
      width: var(--nav-cta-width);
    }
  }
</style>
